PORT=4000

# Supabase (Postgres + RLS)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Nodemailer (Gmail SMTP)
SMTP_USER=
SMTP_PASSWORD=

# Activación de cuenta (pendiente #75) — URL pública de cada PWA, usada para armar el link
# de "primera contraseña" que se manda por email a Familia/Asistente/Círculo de cuidado.
PWA_FAMILIAS_URL=
PWA_ASISTENTES_URL=

# Backup (backend/scripts/backup_a_buckets.mjs) — conexión directa a Postgres para pg_dump
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# Backup — Cloudflare R2 (bucket principal)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Backup — Backblaze B2 (bucket espejo/secundario)
B2_ENDPOINT=
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=

# Web Push (notificaciones push a Asistentes — generar con `npx web-push generate-vapid-keys`)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
